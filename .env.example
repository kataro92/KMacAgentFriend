# KMacAgentFriend daemon configuration

# Server
KAF_HOST=127.0.0.1
KAF_PORT=18750

# Auth — set a fixed token or leave empty to auto-generate on first run
KAF_API_TOKEN=

# Data directory (default: <repo>/data — sandbox, sqlite, memory, knowledge)
# Leave empty to use the project data/ folder (not ~/Library).
KAF_DATA_DIR=

# Comma-separated project roots allowed for file tools (default: repo root)
KAF_PROJECT_DIRS=

# Ollama (Phase 1+)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VLM_MODEL=llava
# Embeddings for long-term memory + knowledge (pull: ollama pull nomic-embed-text)
OLLAMA_EMBED_MODEL=nomic-embed-text

# Performance (16 GB) — keep models resident; serialize heavy inference
PIN_OLLAMA_MODELS=true

# Safety — autopilot off = suggestion only; tool calls per minute (0 disables)
AUTOPILOT_ENABLED=false
TOOL_RATE_LIMIT_PER_MINUTE=60

# Vision — never write captured frames to disk unless enabled
VISION_PERSIST_FRAMES=false

# Mock mode — canned replies so the Swift UI runs without Ollama
MOCK_MODE=false

# Background / Moltbook (Phase 5) — leave MOLTBOOK_URL empty to disable forum feed
MOLTBOOK_URL=
BACKGROUND_INTERVAL_SECONDS=120

# Voice (Phase 1) — install extras: pip install -e ".[voice]"
# Use mlx-community/*-mlx repo IDs (see HF collection mlx-community/whisper)
WHISPER_MODEL=mlx-community/whisper-small-mlx
TTS_LANGUAGE=en

# Optional — faster Hugging Face downloads (never commit a real token)
HF_TOKEN=
