# KMacAgentFriend daemon configuration

# Server
KAF_HOST=127.0.0.1
KAF_PORT=18750

# Auth — set a fixed token or leave empty to auto-generate on first run
KAF_API_TOKEN=

# Data directory (sandbox, sqlite, chroma — later phases)
KAF_DATA_DIR=

# Ollama (Phase 1+)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
